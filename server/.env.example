PORT=3000
HOST=0.0.0.0
# Public URL (required behind Coolify/Cloudflare reverse proxy)
BASE_URL=https://streambooru.example.com

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
JWT_SECRET=change_me_to_a_long_random_string

DATABASE_URL=postgres://user:pass@host:5432/streambooru
PGSSL=false

# AES-256-GCM key derivation (do not lose — existing encrypted site creds become unreadable if changed)
ENC_SECRET=change_me_to_a_long_random_string_for_aes

# Optional webhook signing secret
WEBHOOK_SECRET=
