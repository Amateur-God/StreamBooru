# StreamBooru sync server — optional AtlasAnalytics (requires browser consent)

# App identity (shared AtlasAnalytics bundle)
ATLAS_APP_ID=streambooru
ATLAS_APP_NAME=StreamBooru
ATLAS_CONSENT_VERSION=sb-v1.0 - 22 May 2026
ATLAS_ACCOUNT_PROFILE_TYPE=sync_account

# Require analytics consent before server-side login/session linking
ANALYTICS_REQUIRE_CONSENT=true

# Optional private git repo cloned at build time (Coolify env var)
# ATLAS_ANALYTICS_REPO=https://github.com/Atlas-Tech-Solutions/atlas-analytics.git

OPENPANEL_API_URL=https://telemetry.atlastechsolutions.co.uk
OPENPANEL_SCRIPT_SRC=https://insights.atlastechsolutions.co.uk/op1.js
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
OPENPANEL_DISABLED=false
OPENPANEL_PROFILE_ID_SECRET=
OPENPANEL_ALLOW_LEAD_PROFILE_FALLBACK=false

# Optional HMAC secret for account-linked consent audit request evidence.
# Falls back to OPENPANEL_PROFILE_ID_SECRET / OPENPANEL_CLIENT_SECRET / JWT_SECRET if unset.
CONSENT_AUDIT_HASH_SECRET=

# Swetrix analytics and error diagnostics (optional)
SWETRIX_PROJECT_ID=
SWETRIX_API_URL=https://collector.atlastechsolutions.co.uk/log
SWETRIX_DISABLED=false
SWETRIX_RESPECT_DNT=false
SWETRIX_DEV_MODE=false
